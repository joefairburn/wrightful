{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "tests",
    "tests-dashboard",
    "tests-load",
    "src",
    "playwright.config.ts",
    "playwright.dashboard.config.ts",
    "playwright.load.config.ts",
    "vitest.config.ts",
    "vitest.globalSetup.ts"
  ],
  "exclude": ["node_modules"]
}

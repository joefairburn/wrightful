{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wrightful-test",
  "main": "src/__integration__/entrypoint.ts",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  // Scoped to what integration tests actually touch. Everything the
  // production config has (rate limiters, cron triggers, observability,
  // public asset binding) is intentionally omitted — keeps the miniflare
  // instance small and test startup fast.
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "wrightful-test-artifacts",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "SYNCED_STATE_SERVER",
        "class_name": "SyncedStateServer",
      },
      {
        "name": "TENANT",
        "class_name": "TenantDO",
      },
      {
        "name": "CONTROL",
        "class_name": "ControlDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SyncedStateServer"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["TenantDO"],
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["ControlDO"],
    },
  ],
  "vars": {
    "WRIGHTFUL_MAX_ARTIFACT_BYTES": "52428800",
    "WRIGHTFUL_PUBLIC_URL": "http://localhost:5173",
    "WRIGHTFUL_RUN_STALE_MINUTES": "30",
    // Fixed secret for deterministic artifact-token signatures in tests.
    "BETTER_AUTH_SECRET": "test-secret-please-do-not-use-in-prod",
  },
}

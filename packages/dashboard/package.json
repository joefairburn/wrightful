{
  "name": "@wrightful/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "clean": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "deploy": "npm run build && npm run db:migrate:remote && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "typecheck": "tsgo --noEmit",
    "types": "tsc",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed-api-key": "node scripts/seed-api-key.mjs",
    "db:seed-demo": "node scripts/seed-demo.mjs",
    "fixtures:generate": "node scripts/upload-fixtures.mjs",
    "setup:local": "node scripts/setup-local.mjs"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@base-ui/react": "^1.4.0",
    "@better-auth/kysely-adapter": "^1.6.5",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.1",
    "anser": "^2.3.5",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "geist": "^1.7.0",
    "kysely": "^0.28.15",
    "kysely-d1": "^0.3.0",
    "lucide-react": "^0.469.0",
    "nuqs": "^2.8.9",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-server-dom-webpack": "19.2.5",
    "rwsdk": "^1.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.32.3",
    "@cloudflare/vitest-pool-workers": "^0.14.8",
    "@cloudflare/workers-types": "^4.20260416.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260416.2",
    "@wrightful/reporter": "workspace:*",
    "picocolors": "^1.1.1",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "~7.3.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "D1 database storing runs, test results, tags, annotations, and API keys."
      },
      "R2": {
        "description": "R2 bucket storing uploaded artifacts (traces, screenshots, videos)."
      },
      "ASSETS": {
        "description": "Static assets built by Vite."
      }
    }
  }
}

{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-await-in-loop": "off",
    "typescript/consistent-return": "off",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-unnecessary-type-assertion": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-unused-vars": "error",
    "import/no-cycle": "error"
  },
  "overrides": [
    {
      "files": ["packages/dashboard/**/*.{tsx,jsx}"],
      "plugins": ["typescript", "import", "react"]
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "rules": {
        "typescript/no-explicit-any": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-type-assertion": "off"
      }
    },
    {
      "files": ["packages/dashboard/src/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@/tenant/internal",
                "message": "Raw tenant DO access skips the membership / API-key auth check. Use tenantScopeForUser / tenantScopeForApiKey from `@/tenant` instead. The only legitimate importers are src/tenant/** and src/scheduled.ts (cron watchdog)."
              }
            ]
          }
        ]
      }
    },
    {
      "files": [
        "packages/dashboard/src/tenant/**",
        "packages/dashboard/src/scheduled.ts",
        "packages/dashboard/src/__integration__/**",
        "packages/dashboard/src/__tests__/**"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "ignorePatterns": ["dist", "coverage", ".wrangler", "*.d.ts"],
  "options": {
    "typeAware": true
  }
}

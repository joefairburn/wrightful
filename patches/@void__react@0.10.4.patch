diff --git a/dist/runtime/pages-client.mjs b/dist/runtime/pages-client.mjs
index c4d6ee9bbdb9432a791956c4f137bd861ae6b84e..6095dc6e464a61a62b8ed62d2fce5e090de80800 100644
--- a/dist/runtime/pages-client.mjs
+++ b/dist/runtime/pages-client.mjs
@@ -428,9 +428,19 @@ async function startReactPages(config) {
 		router,
 		viewTransitions: config.viewTransitions
 	});
+	// Deferred pages are server-rendered as <Fragment>{page}<template id=SHELL_END/></Fragment>
+	// (page = child 0 of 2), which forks React's useId tree-context and adds bits
+	// to every id in the page. Mirror that exact root shape here when the marker
+	// survived into #app, so client useId matches the server and Base UI ids don't
+	// mismatch on hydration. Non-deferred pages have no marker -> bare hydrate.
+	// (Only the hydrateRoot path needs this; the data-void-ssr="false" branch is a
+	// fresh client render with no server HTML to match.)
+	const hydrateTree = appEl.querySelector("template#__VOID_DEFERRED_SHELL_END__")
+		? React.createElement(React.Fragment, null, app, React.createElement("template", { id: "__VOID_DEFERRED_SHELL_END__" }))
+		: app;
 	startTransition(() => {
 		if (appEl.getAttribute("data-void-ssr") === "false") createRoot(appEl).render(app);
-		else hydrateRoot(appEl, app);
+		else hydrateRoot(appEl, hydrateTree);
 	});
 	appEl.setAttribute("data-hydrated", "true");
 	engine.start();

# Copy to `.env.local` and fill in. Void's vite plugin loads `.env*` files
# during `vp dev` and uses them to satisfy the schema in `env.ts`.

# Required — public origin of the dashboard. Void auth uses this for
# sign-in / OAuth callback URLs, so it must match the origin your browser
# hits. Locally this is http://localhost:5173. In production, set this
# via `void secret put WRIGHTFUL_PUBLIC_URL` (or in your project secrets
# dashboard) to your actual deployed URL.
WRIGHTFUL_PUBLIC_URL=http://localhost:5173

# Required — signing secret. ≥32 chars (generate with
# `openssl rand -base64 32`). Drives Better Auth's session cookie HMAC
# and our short-lived artifact download tokens. On Void Cloud this is
# auto-created if unset.
BETTER_AUTH_SECRET=replace-me-with-better-auth-secret

# Optional — GitHub OAuth credentials. Void's auth layer expects the
# `AUTH_GITHUB_*` naming and wires them through automatically when
# "github" is in `void.json#auth.providers`. Leave both unset to hide
# the "Continue with GitHub" button.
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=

# Optional — `true` enables open email/password signup. Off by default; on a
# public instance set EMAIL_FROM too so registrations must verify their address.
# ALLOW_OPEN_SIGNUP=true

# Optional — from address for outbound email (sent via the Cloudflare Email
# Service `EMAIL` binding). Must belong to a domain you've onboarded to CES.
# Email is fully optional: leave this unset and the app runs normally — sends
# are skipped gracefully (`isEmailConfigured()` is false). Local `vp dev`
# simulates sends (logs them), so you don't need this to develop.
# e.g. EMAIL_FROM="Wrightful <noreply@mail.example.com>"
# EMAIL_FROM=

# Optional — synthetic-monitor executor. Defaults to `sandbox` (a Void
# Sandbox container), but `vp dev` runs with containers disabled
# (wrangler.jsonc `dev.enable_containers`), so local dev should use the
# in-process `stub` executor — otherwise a scheduled monitor errors at
# execution time. `pnpm setup:local` sets this for you.
# WRIGHTFUL_MONITOR_EXECUTOR=stub

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Required for LOCAL dev + migrations — the Postgres connection string. The app
# is Postgres-only (no zero-config local store), so `vp dev` needs this set.
# Connects DIRECTLY to your Postgres (Hyperdrive is prod-only); also used by
# `pnpm db:migrate` / `db:migrate:remote`. Both postgres:// and postgresql://
# work, incl. ?sslmode=.
#
# `pnpm setup:local` writes this for you: when it's unset/commented it boots a
# local Postgres (docker-compose.pg.yml) and points DATABASE_URL at it. To use a
# hosted Postgres instead — Neon (neon.tech) has a free tier — set it yourself
# and setup:local leaves Docker alone. See SELF-HOSTING.md (repo root).
#
# Port 5432 already in use (e.g. a native Postgres)? Export WRIGHTFUL_PG_PORT
# (e.g. 5433) so the compose container publishes there, and use that port here.
# DATABASE_URL=postgresql://wrightful:wrightful@localhost:5432/wrightful_dev

# ── Own-account `wrangler deploy` config (build-time, NOT worker vars) ───────
# Only for deploying to YOUR OWN Cloudflare account via `pnpm deploy:cf`
# (vs `pnpm deploy` = Void managed platform). Read by scripts/gen-wrangler.mjs
# to materialize wrangler.jsonc — these are deployment-specific, kept out of the
# committed template. Set them in your deploy shell/CI (or here). Unset = the
# generic fallback wrangler.jsonc (so dev / `void deploy` are unaffected).
# The Worker name (any name you like).
# CF_WORKER_NAME=wrightful-dashboard-void
# The R2 bucket (→ STORAGE binding). Create with: wrangler r2 bucket create <name>
# CF_R2_BUCKET=wrightful-artifacts
# The Postgres DB binding (→ HYPERDRIVE). From: wrangler hyperdrive create
# CF_HYPERDRIVE_ID=<your-hyperdrive-config-id>

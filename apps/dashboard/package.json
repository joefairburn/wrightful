{
  "name": "@wrightful/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf:prepare": "node scripts/gen-wrangler.mjs",
    "prebuild": "pnpm run cf:prepare",
    "build": "vp build",
    "predev": "pnpm run cf:prepare",
    "dev": "vp dev",
    "preview": "vp preview",
    "email:dev": "email dev --dir src/emails/previews",
    "prepare:void": "pnpm run cf:prepare && void prepare",
    "typecheck": "void prepare && tsgo --noEmit",
    "predeploy": "pnpm run cf:prepare",
    "deploy": "void deploy",
    "predeploy:cf": "pnpm run cf:prepare",
    "deploy:cf": "vp build && wrangler deploy",
    "db:push": "void db push",
    "db:generate": "void db generate",
    "db:migrate": "void db migrate",
    "db:migrate:remote": "node scripts/migrate-remote.mjs",
    "db:seed": "void db seed",
    "db:status": "void db status",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test run && vp test run -c vitest.workers.config.ts",
    "test:node": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "test:workers": "vp test run -c vitest.workers.config.ts",
    "test:workers:db": "vp test run -c vitest.workers.db.config.ts",
    "db:seed-demo": "node scripts/seed-demo.mjs",
    "fixtures:generate": "node scripts/upload-fixtures.mjs",
    "seed:stream": "node scripts/seed-stream.mjs",
    "setup:local": "node scripts/setup-local.mjs"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@base-ui/react": "^1.4.0",
    "@codemirror/lang-javascript": "^6.2.4",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@polar-sh/better-auth": "^1.8.4",
    "@polar-sh/sdk": "^0.47.1",
    "@react-email/components": "^1.0.12",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.1",
    "@uiw/react-codemirror": "^4.25.4",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "anser": "^2.3.5",
    "aws4fetch": "^1.0.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "geist": "^1.7.0",
    "hono": "^4.11.9",
    "lucide-react": "^0.469.0",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.16",
    "@electric-sql/pglite": "^0.5.2",
    "@playwright/test": "^1.59.1",
    "@react-email/ui": "6.6.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@void/react": "0.9.2",
    "@wrightful/reporter": "workspace:*",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-orm": "0.45.2",
    "happy-dom": "^20.9.0",
    "pg": "8.21.0",
    "picocolors": "^1.1.1",
    "react-email": "^6.6.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "void": "0.9.2",
    "wrangler": "4.94.0"
  }

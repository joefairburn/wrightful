{
  "name": "@wrightful/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf:prepare": "node scripts/gen-wrangler.mjs",
    "vendor:trace-viewer": "node scripts/vendor-trace-viewer.mjs",
    "sync:trace-vendor": "node scripts/sync-trace-vendor.mjs",
    "prebuild": "pnpm run cf:prepare && pnpm run vendor:trace-viewer",
    "build": "vp build",
    "postbuild": "node scripts/void-patches/strip-d1-binding.mjs && node scripts/void-patches/add-ws-do-migration.mjs",
    "predev": "pnpm run cf:prepare && pnpm run vendor:trace-viewer",
    "dev": "vp dev",
    "preview": "vp preview",
    "email:dev": "email dev --dir src/emails/previews",
    "prepare:void": "pnpm run cf:prepare && void prepare",
    "typecheck": "void prepare && tsgo --noEmit",
    "predeploy": "pnpm run cf:prepare && pnpm run vendor:trace-viewer",
    "deploy": "void deploy",
    "deploy:cf": "pnpm build && wrangler deploy",
    "db:push": "void db push",
    "db:generate": "void db generate",
    "db:migrate": "void db migrate",
    "db:migrate:remote": "node scripts/migrate-remote.mjs",
    "db:seed": "void db seed",
    "db:status": "void db status",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test run && vp test run -c vitest.workers.config.ts",
    "test:node": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "test:workers": "vp test run -c vitest.workers.config.ts",
    "test:workers:db": "vp test run -c vitest.workers.db.config.ts",
    "db:seed-demo": "node scripts/seed-demo.mjs",
    "fixtures:generate": "node scripts/upload-fixtures.mjs",
    "seed:stream": "node scripts/seed-stream.mjs",
    "seed:sharded": "node scripts/seed-sharded.mjs",
    "setup:local": "node scripts/setup-local.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/lang-javascript": "^6.2.4",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@fontsource-variable/space-grotesk": "^5.3.0",
    "@hono/mcp": "^0.3.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/javascript": "^1.5.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@polar-sh/better-auth": "^1.8.4",
    "@polar-sh/sdk": "^0.49.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query": "^5.101.4",
    "@uiw/react-codemirror": "^4.25.11",
    "@visx/group": "^4.0.0",
    "@visx/scale": "^4.0.0",
    "@visx/shape": "^4.0.0",
    "anser": "^2.3.5",
    "aws4fetch": "^1.0.20",
    "better-all": "^0.0.8",
    "better-auth": "^1.6.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "geist": "^1.7.2",
    "hono": "^4.12.31",
    "lucide-react": "^1.25.0",
    "react": "19.2.8",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.7",
    "@electric-sql/pglite": "^0.5.4",
    "@playwright/test": "^1.61.1",
    "@react-email/ui": "6.9.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "@void/react": "0.10.10",
    "@wrightful/reporter": "workspace:*",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-orm": "0.45.2",
    "happy-dom": "^20.11.0",
    "pg": "8.22.0",
    "picocolors": "^1.1.1",
    "playwright-core": "^1.61.1",
    "react-email": "^6.9.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "void": "0.10.10",
    "wrangler": "4.113.0"
  }
}

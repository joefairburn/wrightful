{
  "name": "wrightful",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @wrightful/dashboard dev",
    "build": "pnpm --filter @wrightful/dashboard build && pnpm --filter @wrightful/reporter build",
    "test": "pnpm --filter @wrightful/dashboard test && pnpm --filter @wrightful/reporter test",
    "test:coverage": "pnpm --filter @wrightful/dashboard test:coverage && pnpm --filter @wrightful/reporter test:coverage",
    "test:e2e": "pnpm --filter @wrightful/e2e test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "setup:local": "pnpm --filter @wrightful/dashboard setup:local",
    "fixtures:generate": "pnpm --filter @wrightful/dashboard fixtures:generate",
    "seed:stream": "pnpm --filter @wrightful/dashboard seed:stream",
    "ci:local": "npx @redwoodjs/agent-ci run --workflow .github/workflows/ci.yml",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm --filter @wrightful/reporter build && changeset publish",
    "deploy:void": "pnpm --filter @wrightful/dashboard run deploy",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@redwoodjs/agent-ci": "^0.17.1",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d"
}

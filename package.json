{
  "name": "wrightful",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @wrightful/dashboard dev",
    "build": "pnpm --filter @wrightful/dashboard build && pnpm --filter @wrightful/reporter build",
    "test": "pnpm --filter @wrightful/dashboard test && pnpm --filter @wrightful/reporter test",
    "test:e2e": "pnpm --filter @wrightful/e2e test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "typecheck": "pnpm --filter @wrightful/dashboard typecheck && pnpm --filter @wrightful/reporter typecheck",
    "setup:local": "pnpm --filter @wrightful/dashboard setup:local",
    "fixtures:generate": "pnpm --filter @wrightful/dashboard fixtures:generate",
    "ci:local": "npx @redwoodjs/agent-ci run --workflow .github/workflows/ci.yml",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm --filter @wrightful/reporter build && changeset publish",
    "deploy": "pnpm --filter @wrightful/dashboard run deploy",
    "deploy:remote": "pnpm --filter @wrightful/dashboard run deploy:remote",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@redwoodjs/agent-ci": "^0.10.7",
    "@typescript/native-preview": "7.0.0-dev.20260416.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --write"
    ],
    "*.{json,jsonc,md,yaml,yml,css}": "oxfmt --write"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "better-sqlite3"
    ]
  }
}

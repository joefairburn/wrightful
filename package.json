{
  "name": "greenroom",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @greenroom/dashboard dev",
    "build": "pnpm --filter @greenroom/dashboard build",
    "cli": "pnpm --filter @greenroom/cli",
    "test": "pnpm --filter @greenroom/cli test && pnpm --filter @greenroom/dashboard test",
    "test:e2e": "pnpm --filter @greenroom/e2e test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "typecheck": "pnpm --filter @greenroom/cli typecheck && pnpm --filter @greenroom/dashboard typecheck",
    "ci:local": "npx @redwoodjs/agent-ci run --workflow .github/workflows/ci.yml",
    "prepare": "husky"
  },
  "devDependencies": {
    "@redwoodjs/agent-ci": "^0.10.7",
    "@typescript/native-preview": "7.0.0-dev.20260416.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.{json,jsonc,md,yaml,yml,css}": "oxfmt --write"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "better-sqlite3"
    ]
  }
}
